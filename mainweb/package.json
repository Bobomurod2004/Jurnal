{
  "name": "mainweb",
  "version": "1.0.0",
  "description": "Journal management system with Tailwind CSS compilation",
  "scripts": {
    "build:css": "postcss src/styles.css -o static/styles.css",
    "watch:css": "postcss src/styles.css -o static/styles.css --watch",
    "dev": "npm run watch:css"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "flag-icons": "^7.3.2",
    "lightningcss-linux-x64-gnu": "^1.31.1",
    "postcss": "^8.5.1",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^4.0.0",
    "tailwindcss-animated": "^2.0.0",
    "tailwindcss-intersect": "^2.1.0"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
